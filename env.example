# CoinCoin Proxy Configuration
# Railway Variables: enter raw values without surrounding quotes.

# Admin
COINCOIN_ADMIN_TOKEN=change-me

# Monitoring / Checkly
COINCOIN_MONITORING_TOKEN=
COINCOIN_MONITORING_API_KEY=
COINCOIN_MONITORING_PUBLIC_BASE_URL=
COINCOIN_MONITORING_GATEWAY_HEALTH_URL=
COINCOIN_MONITORING_CHAT_MODEL=
COINCOIN_MONITORING_RESPONSES_MODEL=
COINCOIN_MONITORING_CPA_BASE_URL=
COINCOIN_MONITORING_CPA_API_KEY=
COINCOIN_MONITORING_CPA_CHAT_MODEL=
COINCOIN_MONITORING_CPA_RESPONSES_MODEL=
COINCOIN_MONITORING_TIMEOUT_SECONDS=45

# Upstream Azure OpenAI
COINCOIN_UPSTREAM_BASE_URL=https://hc-instance-eastus2.cognitiveservices.azure.com/openai/v1
COINCOIN_UPSTREAM_API_KEY=your-azure-api-key
COINCOIN_FIXED_MODEL=gpt-5.2-codex
COINCOIN_MODEL_CATALOG_PATH=config/model_catalog.json
COINCOIN_MODEL_ALIAS_OVERRIDES_PATH=config/model_alias_overrides.json
COINCOIN_MODEL_ALIAS_OVERRIDES_REFRESH_INTERVAL=10

# Native Gemini CPA lane for Gemini text / images.
# IMPORTANT: this is the Gemini CPA service, not the Codex/GPT CPA service.
# Set the root CPA URL without a trailing slash; the catalog appends /v1.
COINCOIN_GEMINI_CPA_BASE_URL=https://gemini-c.up.railway.app
COINCOIN_GEMINI_CPA_API_KEY=your-gemini-cpa-key
COINCOIN_GEMINI_CPA_AUTH_STYLE=bearer
COINCOIN_GEMINI_CPA_ALLOWED_FAILS=3
COINCOIN_GEMINI_CPA_COOLDOWN_SECONDS=30

# Optional legacy/internal OpenAI-compatible gateway lane.
# The checked-in model catalog will append /v1 automatically.
COINCOIN_GATEWAY_BASE_URL=
COINCOIN_GATEWAY_API_KEY=
COINCOIN_GATEWAY_AUTH_STYLE=bearer

# Cached tokens discount (fraction of input price charged for cached tokens)
COINCOIN_CACHE_DISCOUNT_RATE=0.1

# Router (optional; default disabled)
COINCOIN_ROUTER_ENABLED=false
COINCOIN_ROUTER_TOOL_COUNT_THRESHOLD=2

# Cheap model (optional)
COINCOIN_CHEAP_MODEL=gpt-4o-mini
COINCOIN_CHEAP_UPSTREAM_URL=
COINCOIN_CHEAP_API_KEY=
COINCOIN_CHEAP_PRICE_INPUT=15
COINCOIN_CHEAP_PRICE_OUTPUT=60

# Gemini pricing examples (optional; catalog defaults are used if omitted)
COINCOIN_GEMINI_BALANCED_INPUT_PRICE=10
COINCOIN_GEMINI_BALANCED_OUTPUT_PRICE=40
COINCOIN_GEMINI_FAST_INPUT_PRICE=30
COINCOIN_GEMINI_FAST_OUTPUT_PRICE=250
COINCOIN_GEMINI_REASONING_INPUT_PRICE=125
COINCOIN_GEMINI_REASONING_OUTPUT_PRICE=1000
COINCOIN_GEMINI_IMAGE_PRICE=6.7

# Database (MySQL/TiDB)
COINCOIN_DB_HOST=localhost
COINCOIN_DB_PORT=4000
COINCOIN_DB_NAME=coincoin
COINCOIN_DB_USER=root
COINCOIN_DB_PASSWORD=your-db-password

# Station center public URLs
# Safe fallback on the shared Cloudflare domain:
COINCOIN_STATION_PUBLIC_BASE_URL=https://coincoin.ai
COINCOIN_STATION_PORTAL_PATH_PREFIX=/s
COINCOIN_STATION_API_PATH_PREFIX=/v1
# Optional explicit API base if the public API is not the same host as the portal:
# COINCOIN_STATION_API_BASE_URL=https://coincoin.ai/v1
# Enable after Cloudflare wildcard DNS/TLS is ready:
# COINCOIN_STATION_PORTAL_DOMAIN=station.coincoin.ai
# COINCOIN_STATION_API_DOMAIN=api.coincoin.ai
