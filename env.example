# CoinCoin Proxy Configuration

# Admin
COINCOIN_ADMIN_TOKEN=change-me

# Upstream Azure OpenAI
COINCOIN_UPSTREAM_BASE_URL=https://hc-instance-eastus2.cognitiveservices.azure.com/openai/v1
COINCOIN_UPSTREAM_API_KEY=your-azure-api-key
COINCOIN_FIXED_MODEL=gpt-5.2-codex
COINCOIN_MODEL_CATALOG_PATH=config/model_catalog.json

# Internal LiteLLM gateway for Gemini text / images
# IMPORTANT: set the root gateway URL without a trailing slash.
# The checked-in model catalog will append /v1 automatically.
COINCOIN_GATEWAY_BASE_URL=https://transfer-station-litellm-gateway-production.up.railway.app
COINCOIN_GATEWAY_API_KEY=your-internal-gateway-key
COINCOIN_GATEWAY_AUTH_STYLE=bearer

# Cached tokens discount (fraction of input price charged for cached tokens)
COINCOIN_CACHE_DISCOUNT_RATE=0.5

# Router (optional; default disabled)
COINCOIN_ROUTER_ENABLED=false
COINCOIN_ROUTER_TOOL_COUNT_THRESHOLD=2

# Cheap model (optional)
COINCOIN_CHEAP_MODEL=gpt-4o-mini
COINCOIN_CHEAP_UPSTREAM_URL=
COINCOIN_CHEAP_API_KEY=
COINCOIN_CHEAP_PRICE_INPUT=15
COINCOIN_CHEAP_PRICE_OUTPUT=60

# Gemini pricing examples (optional; defaults to 0 if omitted)
COINCOIN_GEMINI_BALANCED_INPUT_PRICE=0
COINCOIN_GEMINI_BALANCED_OUTPUT_PRICE=0
COINCOIN_GEMINI_FAST_INPUT_PRICE=0
COINCOIN_GEMINI_FAST_OUTPUT_PRICE=0
COINCOIN_GEMINI_REASONING_INPUT_PRICE=0
COINCOIN_GEMINI_REASONING_OUTPUT_PRICE=0
COINCOIN_GEMINI_IMAGE_PRICE=0

# Database (MySQL/TiDB)
COINCOIN_DB_HOST=localhost
COINCOIN_DB_PORT=4000
COINCOIN_DB_NAME=coincoin
COINCOIN_DB_USER=root
COINCOIN_DB_PASSWORD=your-db-password
